    void testInitializeDataSourceMetadata_WithMixedHealthStates() {
        // Given
        engine = new DataSynchronizationEngine(factory);
        
        TestableInMemoryDataSource<SimpleUser> healthy1 = createTestDataSource("healthy1", SimpleUser.class);
