    @Test
    void testMultipleDatasources_PartialFailure_OthersSucceed() {
        // Given
        engine = new DataSynchronizationEngine(factory);
        
        TestableInMemoryDataSource<SimpleUser> healthyDs1 = createTestDataSource("healthy1", SimpleUser.class);
        TestableInMemoryDataSource<SimpleUser> failingDs = createTestDataSource("failing", SimpleUser.class);
        TestableInMemoryDataSource<SimpleUser> healthyDs2 = createTestDataSource("healthy2", SimpleUser.class);
        
        setDataSourceData(healthyDs1, createUser(1L, "User1"));
        failingDs.setFailOnRead(true);
        setDataSourceData(healthyDs2, createUser(2L, "User2"));
        
        factory.registerDataSource("healthy1", healthyDs1, java.time.Duration.ofMinutes(5));
        factory.registerDataSource("failing", failingDs, java.time.Duration.ofMinutes(5));
        factory.registerDataSource("healthy2", healthyDs2, java.time.Duration.ofMinutes(5));
        
        InMemoryDataStore<SimpleUser> store1 = factory.buildInMemoryStore(SimpleUser.class)
                .withPrimaryDataSource("healthy1")
                .build();
        InMemoryDataStore<SimpleUser> store2 = factory.buildInMemoryStore(SimpleUser.class)
                .withPrimaryDataSource("failing")
                .build();
        InMemoryDataStore<SimpleUser> store3 = factory.buildInMemoryStore(SimpleUser.class)
                .withPrimaryDataSource("healthy2")
                .build();
        
        // When
        engine.initialize();
        waitForSync();

        // Then - Healthy datasources should succeed, failing should not
        assertEquals(1, store1.size(), "Healthy1 store should have data");
        assertTrue(store2.findAll().isEmpty(), "Failing store should be empty");
        assertEquals(1, store3.size(), "Healthy2 store should have data");
        
        DataSourceSyncMetadata metadata1 = engine.getDataSourceMetadataInternal().get("healthy1");
        DataSourceSyncMetadata metadata2 = engine.getDataSourceMetadataInternal().get("failing");
        DataSourceSyncMetadata metadata3 = engine.getDataSourceMetadataInternal().get("healthy2");
        
        assertTrue(metadata1.isHealthy(), "Healthy1 should be healthy");
        assertFalse(metadata2.isHealthy(), "Failing should be unhealthy");
        assertTrue(metadata3.isHealthy(), "Healthy2 should be healthy");
    }

