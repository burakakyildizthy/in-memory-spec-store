    @Test
    @Timeout(value = 15, unit = TimeUnit.SECONDS)
    void testDatasourceIntervalExpiration_TriggersSync() throws InterruptedException {
        // Given
        engine = new DataSynchronizationEngine(factory);
        
        TestableInMemoryDataSource<SimpleUser> dataSource = createTestDataSource("users", SimpleUser.class);
        setDataSourceData(dataSource, createUser(1L, "User1"));
        
        factory.registerDataSource("users", dataSource, java.time.Duration.ofSeconds(2));
        
        InMemoryDataStore<SimpleUser> store = factory.buildInMemoryStore(SimpleUser.class)
                .withPrimaryDataSource("users")
                .build();
        
        engine.initialize();
        waitForSync();
        
        DataSourceSyncMetadata metadata = engine.getDataSourceMetadataInternal().get("users");
        assertNotNull(metadata, "Metadata should exist");
        
        LocalDateTime firstSyncTime = metadata.getLastSyncTime();
        assertNotNull(firstSyncTime, "First sync time should be recorded");

        // When - Wait for interval to expire
        Thread.sleep(3000);

        // Then - Should have synced again
        LocalDateTime secondSyncTime = metadata.getLastSyncTime();
        assertTrue(secondSyncTime.isAfter(firstSyncTime) || secondSyncTime.isEqual(firstSyncTime),
            "Should have attempted sync after interval expiration");
    }

    @Test
    @Timeout(value = 20, unit = TimeUnit.SECONDS)
    void testMultipleDatasources_WithDifferentIntervals() throws InterruptedException {
        // Given
        engine = new DataSynchronizationEngine(factory);
        
        TestableInMemoryDataSource<SimpleUser> fastDs = createTestDataSource("fast", SimpleUser.class);
        TestableInMemoryDataSource<SimpleUser> mediumDs = createTestDataSource("medium", SimpleUser.class);
        TestableInMemoryDataSource<SimpleUser> slowDs = createTestDataSource("slow", SimpleUser.class);
        
        setDataSourceData(fastDs, createUser(1L, "Fast1"));
        setDataSourceData(mediumDs, createUser(2L, "Medium1"));
        setDataSourceData(slowDs, createUser(3L, "Slow1"));
        
        // Different intervals: 1s, 3s, 5s
        factory.registerDataSource("fast", fastDs, java.time.Duration.ofSeconds(1));
        factory.registerDataSource("medium", mediumDs, java.time.Duration.ofSeconds(3));
        factory.registerDataSource("slow", slowDs, java.time.Duration.ofSeconds(5));
        
        InMemoryDataStore<SimpleUser> fastStore = factory.buildInMemoryStore(SimpleUser.class)
                .withPrimaryDataSource("fast")
                .build();
        InMemoryDataStore<SimpleUser> mediumStore = factory.buildInMemoryStore(SimpleUser.class)
                .withPrimaryDataSource("medium")
                .build();
        InMemoryDataStore<SimpleUser> slowStore = factory.buildInMemoryStore(SimpleUser.class)
                .withPrimaryDataSource("slow")
                .build();
        
        engine.initialize();
        waitForSync();
        
        // Record initial sync times
        DataSourceSyncMetadata fastMetadata = engine.getDataSourceMetadataInternal().get("fast");
        DataSourceSyncMetadata mediumMetadata = engine.getDataSourceMetadataInternal().get("medium");
        DataSourceSyncMetadata slowMetadata = engine.getDataSourceMetadataInternal().get("slow");
        
        LocalDateTime fastInitialSync = fastMetadata.getLastSyncTime();
        LocalDateTime mediumInitialSync = mediumMetadata.getLastSyncTime();
        LocalDateTime slowInitialSync = slowMetadata.getLastSyncTime();

        // When - Wait for fast datasource interval to expire (2 seconds)
        Thread.sleep(2000);

        // Then - Fast datasource should have synced again, others should not
        LocalDateTime fastAfter2s = fastMetadata.getLastSyncTime();
        LocalDateTime mediumAfter2s = mediumMetadata.getLastSyncTime();
        LocalDateTime slowAfter2s = slowMetadata.getLastSyncTime();
        
        assertTrue(fastAfter2s.isAfter(fastInitialSync) || !fastAfter2s.equals(fastInitialSync),
            "Fast datasource should have synced after 2 seconds");
        
        // When - Wait for medium datasource interval to expire (additional 2 seconds = 4s total)
        Thread.sleep(2000);

        // Then - Medium datasource should have synced
        LocalDateTime mediumAfter4s = mediumMetadata.getLastSyncTime();
        assertTrue(mediumAfter4s.isAfter(mediumInitialSync) || !mediumAfter4s.equals(mediumInitialSync),
            "Medium datasource should have synced after 4 seconds");
    }

    @Test
    @Timeout(value = 10, unit = TimeUnit.SECONDS)
    void testScheduling_ContinuesAfterSyncFailure() throws InterruptedException {
        // Given
        engine = new DataSynchronizationEngine(factory);
        
        TestableInMemoryDataSource<SimpleUser> dataSource = createTestDataSource("users", SimpleUser.class);
        setDataSourceData(dataSource, createUser(1L, "User1"));
        
        factory.registerDataSource("users", dataSource, java.time.Duration.ofSeconds(2));
        
        InMemoryDataStore<SimpleUser> store = factory.buildInMemoryStore(SimpleUser.class)
                .withPrimaryDataSource("users")
                .build();
        
        engine.initialize();
        waitForSync();
        
        assertEquals(1, store.size(), "Initial sync should succeed");

        // When - Make datasource fail temporarily
        dataSource.setFailOnRead(true);
        Thread.sleep(3000); // Wait for interval to trigger failed sync
        
        // Recover datasource
        dataSource.setFailOnRead(false);
        setDataSourceData(dataSource, createUser(1L, "User1"), createUser(2L, "User2"));
        Thread.sleep(3000); // Wait for next interval

        // Then - Scheduling should continue and sync should succeed after recovery
        assertTrue(engine.isRunning(), "Engine should still be running");
        // Store may or may not have updated depending on timing, but engine should be healthy
    }

    // ==================== Lock Mechanism Tests ====================
    @Test
    @Timeout(value = 10, unit = TimeUnit.SECONDS)
    void testLockPreventsConcurrentSynchronization() throws InterruptedException {
        // Given
        engine = new DataSynchronizationEngine(factory);
        TestableInMemoryDataSource<SimpleUser> dataSource = createTestDataSource("users", SimpleUser.class);
        factory.registerDataSource("users", dataSource, Duration.ofMinutes(5));
        engine.initialize();

        CountDownLatch syncStarted = new CountDownLatch(1);
        CountDownLatch syncCanComplete = new CountDownLatch(1);
        AtomicInteger syncCount = new AtomicInteger(0);

        // When - Start first sync in separate thread
        Thread thread1 = new Thread(() -> {
            engine.getSyncLock().lock();
            try {
                syncStarted.countDown();
                syncCanComplete.await(5, TimeUnit.SECONDS);
                syncCount.incrementAndGet();
            } catch (InterruptedException e) {
                Thread.currentThread().interrupt();
            } finally {
                engine.getSyncLock().unlock();
            }
        });

        thread1.start();
        syncStarted.await(2, TimeUnit.SECONDS);

        // Try to acquire lock from main thread (should fail immediately)
        boolean acquired = engine.getSyncLock().tryLock(100, TimeUnit.MILLISECONDS);

        // Then
        assertFalse(acquired, "Lock should not be acquired while another thread holds it");

        // Cleanup
        syncCanComplete.countDown();
        thread1.join(2000);
    }

    @Test
    @Timeout(value = 10, unit = TimeUnit.SECONDS)
    void testReentrantCallDetection() {
        // Given
        engine = new DataSynchronizationEngine(factory);
        TestableInMemoryDataSource<SimpleUser> dataSource = createTestDataSource("users", SimpleUser.class);
        factory.registerDataSource("users", dataSource, Duration.ofMinutes(5));
        engine.initialize();

        // When - Acquire lock and try to trigger sync (reentrant call)
        engine.getSyncLock().lock();
        try {
            engine.synchronizeDataSource("users");
            // triggerGlobalSynchronization should detect reentrant call and return early
            // This should not block or throw exception
        } finally {
            engine.getSyncLock().unlock();
        }

        // Then - Should complete without blocking
        assertTrue(true, "Reentrant call should be detected and handled gracefully");
    }

    @Test
    @Timeout(value = 10, unit = TimeUnit.SECONDS)
    void testLockIsReleasedAfterSync() {
        // Given
        engine = new DataSynchronizationEngine(factory);
        TestableInMemoryDataSource<SimpleUser> dataSource = createTestDataSource("users", SimpleUser.class);
        setDataSourceData(dataSource, createUser(1L, "User1"));
        factory.registerDataSource("users", dataSource, Duration.ofMinutes(5));
        engine.initialize();

        // When
        engine.synchronizeDataSource("users");

        // Give some time for sync to complete
        try {
            Thread.sleep(500);
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
        }

        // Then - Lock should be released
        boolean acquired = engine.getSyncLock().tryLock();
        assertTrue(acquired, "Lock should be released after synchronization");
        if (acquired) {
            engine.getSyncLock().unlock();
        }
    }

    // ==================== Atomic Swap Tests ====================
    @Test
    void testAtomicDataVersionSwap() {
        // Given
        engine = new DataSynchronizationEngine(factory);
        TestableInMemoryDataSource<SimpleUser> dataSource = createTestDataSource("users", SimpleUser.class);
        setDataSourceData(dataSource, createUser(1L, "User1"));
        factory.registerDataSource("users", dataSource, Duration.ofMinutes(5));
        engine.initialize();

        DataVersion initialVersion = engine.getCurrentDataVersion();
        long initialVersionNumber = initialVersion.getVersion();

        // When
        engine.synchronizeDataSource("users");

        // Give time for sync to complete
        waitForSync();

        // Then
        DataVersion newVersion = engine.getCurrentDataVersion();
        assertNotSame(initialVersion, newVersion, "DataVersion should be swapped");
        assertTrue(newVersion.getVersion() > initialVersionNumber,
                "Version number should be incremented");
    }

    @Test
    void testDataVersionIncrementsCorrectly() {
